+import os
+from datetime import datetime
+
+import easyocr
+import pyautogui
+import pygetwindow as gw
+import ollama
+
+SCREENSHOT_FOLDER = "screenshots"
+os.makedirs(SCREENSHOT_FOLDER, exist_ok=True)
+
+OCR_READER = easyocr.Reader(["en"], gpu=False)
+
+# IMPORTANT: use exact model name from `ollama list`
+BRAIN_MODEL = "llama3.1:8b"
+
+
+def get_active_window_title():
+    try:
+        window = gw.getActiveWindow()
+        return window.title if window else "Unknown"
+    except Exception:
+        return "Unknown"
+
+
+def take_full_screenshot():
+    filename = f"full_screen_{datetime.now().strftime('%Y%m%d_%H%M%S')}.png"
+    path = os.path.join(SCREENSHOT_FOLDER, filename)
+
+    screenshot = pyautogui.screenshot()
+    screenshot.save(path)
+
+    return path
+
+
+def read_screen_text(image_path):
+    result = OCR_READER.readtext(image_path)
+
+    lines = []
+
+    for item in result:
+        text = item[1].strip()
+
+        if len(text) < 2:
+            continue
+
+        junk_words = [
+            "CRLF",
+            "UTF-8",
+            "ENG",
+            "IN",
+            "Search",
+            "Ask anything",
+            "Instant",
+            "ChatGPT can make mistakes",
+        ]
+
+        if text in junk_words:
+            continue
+
+        lines.append(text)
+
+    return "\n".join(lines)
+
+
+def summarize_screen(active_window, ocr_text):
+    prompt = f"""
+You are ASTRA's multi-window screen context module.
+
+Active window title:
+{active_window}
+
+Text visible across the full screen:
+{ocr_text}
+
+Task:
+Explain what is open on the user's screen.
+Separate the answer by likely apps/windows.
+Mention ChatGPT/browser and PyCharm/IDE if visible.
+Do not overguess.
+Use 4 short bullet points only.
+"""
+
+    response = ollama.chat(
+        model=BRAIN_MODEL,
+        messages=[
+            {
+                "role": "user",
+                "content": prompt
+            }
+        ]
+    )
+
+    return response["message"]["content"]
+
+
+if __name__ == "__main__":
+    print("ASTRA is checking full screen context...")
+
+    active_window = get_active_window_title()
+    image_path = take_full_screenshot()
+    ocr_text = read_screen_text(image_path)
+
+    print("\n========== ACTIVE WINDOW ==========\n")
+    print(active_window)
+
+    print("\n========== FULL SCREEN OCR TEXT ==========\n")
+    print(ocr_text)
+
+    print("\n========== ASTRA FULL SCREEN CONTEXT ==========\n")
+    summary = summarize_screen(active_window, ocr_text)
+    print(summary)
